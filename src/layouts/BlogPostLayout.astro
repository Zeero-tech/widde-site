---
import BaseLayout from './BaseLayout.astro'

export interface Props {
  title: string
  description: string
  category: string
  publishedAt: Date
  updatedAt?: Date
  cover?: string
  coverAlt?: string
  author: string
  slug: string
}

const { title, description, category, publishedAt, updatedAt, cover, coverAlt, author, slug } = Astro.props
const canonical = `https://widde.io/blog/${slug}`
const formatter = new Intl.DateTimeFormat('pt-BR', { day: '2-digit', month: 'long', year: 'numeric' })
---

<BaseLayout
  title={`${title} | Blog Widde`}
  description={description}
  canonical={canonical}
  ogImage={cover ?? 'https://widde.io/og-image.jpg'}
  ogType="article"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'BlogPosting',
      headline: title,
      description,
      image: cover,
      datePublished: publishedAt.toISOString(),
      dateModified: (updatedAt ?? publishedAt).toISOString(),
      author: { '@type': 'Organization', name: author },
      publisher: {
        '@type': 'Organization',
        name: 'Widde',
        logo: { '@type': 'ImageObject', url: 'https://widde.io/logo.png' },
      },
      mainEntityOfPage: { '@type': 'WebPage', '@id': canonical },
    })} />
  </Fragment>

  <article class="max-w-3xl mx-auto px-5 md:px-8 py-12 md:py-20">
    <nav class="mb-6 text-sm text-text-muted">
      <a href="/" class="hover:text-charcoal">Home</a>
      <span class="mx-2">/</span>
      <a href="/blog" class="hover:text-charcoal">Blog</a>
    </nav>

    <header class="mb-8 md:mb-12">
      <p class="text-xs md:text-sm font-bold text-text-muted uppercase tracking-[1px] mb-3">
        {category}
      </p>
      <h1 class="text-4xl md:text-6xl font-bold text-charcoal leading-tight mb-4">
        {title}
      </h1>
      <p class="text-lg md:text-xl text-text-muted leading-relaxed mb-6">
        {description}
      </p>
      <div class="flex items-center gap-3 text-sm text-text-muted">
        <span>{author}</span>
        <span>·</span>
        <time datetime={publishedAt.toISOString()}>{formatter.format(publishedAt)}</time>
      </div>
    </header>

    {cover && (
      <img
        src={cover}
        alt={coverAlt ?? title}
        class="w-full rounded-2xl mb-10 md:mb-14"
        loading="eager"
      />
    )}

    <div class="prose-content text-text-body">
      <slot />
    </div>

    <footer class="mt-16 pt-8 border-t border-surface-border">
      <a href="/blog" class="font-bold text-navy hover:underline">← Voltar para o blog</a>
    </footer>
  </article>

  <style is:global>
    .prose-content {
      font-size: 1.125rem;
      line-height: 1.75;
    }
    .prose-content h2 {
      font-size: 2rem;
      font-weight: 700;
      color: var(--color-charcoal);
      margin-top: 2.5rem;
      margin-bottom: 1rem;
      line-height: 1.2;
    }
    .prose-content h3 {
      font-size: 1.5rem;
      font-weight: 700;
      color: var(--color-charcoal);
      margin-top: 2rem;
      margin-bottom: 0.75rem;
      line-height: 1.3;
    }
    .prose-content p {
      margin-bottom: 1.25rem;
    }
    .prose-content a {
      color: var(--color-brand);
      text-decoration: underline;
      text-underline-offset: 3px;
    }
    .prose-content a:hover {
      color: var(--color-brand-dark);
    }
    .prose-content ul,
    .prose-content ol {
      margin: 1.25rem 0;
      padding-left: 1.5rem;
    }
    .prose-content ul { list-style: disc; }
    .prose-content ol { list-style: decimal; }
    .prose-content li {
      margin-bottom: 0.5rem;
    }
    .prose-content blockquote {
      border-left: 4px solid var(--color-brand);
      padding-left: 1.25rem;
      margin: 1.5rem 0;
      color: var(--color-text-muted);
      font-style: italic;
    }
    .prose-content code {
      background: var(--color-surface-dark);
      padding: 0.15em 0.4em;
      border-radius: 4px;
      font-size: 0.9em;
      font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    }
    .prose-content pre {
      background: var(--color-ink);
      color: #f5f5f5;
      padding: 1.25rem;
      border-radius: 12px;
      overflow-x: auto;
      margin: 1.5rem 0;
    }
    .prose-content pre code {
      background: transparent;
      padding: 0;
      color: inherit;
    }
    .prose-content img {
      border-radius: 12px;
      margin: 1.5rem 0;
    }
    .prose-content hr {
      border: 0;
      border-top: 1px solid var(--color-surface-border);
      margin: 2.5rem 0;
    }
  </style>
</BaseLayout>
