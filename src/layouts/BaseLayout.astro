---
import '../styles/global.css'
import { ClientRouter } from 'astro:transitions'

interface Props {
  title: string
  description: string
  canonical: string
  noindex?: boolean
  ogTitle?: string
  ogDescription?: string
  ogUrl?: string
  ogImage?: string
  ogType?: string
  datePublished?: string
  author?: string
}

const {
  title,
  description,
  canonical,
  noindex,
  ogTitle,
  ogDescription,
  ogUrl,
  ogImage,
  ogType,
  datePublished,
  author,
} = Astro.props

const resolvedOgImage = ogImage ?? 'https://widde.io/assets/logo_cover.jpeg'
const resolvedOgType = ogType ?? 'website'

const blogPostingSchema = resolvedOgType === 'article' ? {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "headline": title,
  "description": description,
  "image": resolvedOgImage,
  "datePublished": datePublished,
  "author": {
    "@type": "Person",
    "name": author ?? "Equipe Widde",
    "url": "https://widde.io"
  },
  "publisher": {
    "@type": "Organization",
    "name": "Widde",
    "logo": {
      "@type": "ImageObject",
      "url": "https://widde.io/logo.png"
    }
  },
  "mainEntityOfPage": canonical
} : null

function generateBreadcrumbs(url: string, pageTitle: string) {
  try {
    const parts = new URL(url).pathname.split('/').filter(Boolean)
    if (parts.length < 2) return null
    const crumbs = [{ name: 'Home', url: 'https://widde.io/' }]
    if (parts[0] === 'blog') {
      crumbs.push({ name: 'Blog', url: 'https://widde.io/blog' })
      crumbs.push({ name: pageTitle, url })
    } else if (parts[0] === 'case') {
      crumbs.push({ name: 'Cases de Sucesso', url: 'https://widde.io/cases' })
      crumbs.push({ name: pageTitle, url })
    }
    return crumbs.length > 1 ? crumbs : null
  } catch { return null }
}

const breadcrumbs = generateBreadcrumbs(canonical, title)
const breadcrumbSchema = breadcrumbs ? {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": breadcrumbs.map((crumb, i) => ({
    "@type": "ListItem",
    "position": i + 1,
    "name": crumb.name,
    "item": crumb.url
  }))
} : null
---

<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

  <title>{title}</title>
  <meta name="description" content={description} />
  <meta name="robots" content={noindex ? "noindex, nofollow" : "index, follow"} />
  <link rel="canonical" href={canonical} />

  <meta property="og:type" content={resolvedOgType} />
  <meta property="og:title" content={ogTitle ?? title} />
  <meta property="og:description" content={ogDescription ?? description} />
  <meta property="og:url" content={ogUrl ?? canonical} />
  <meta property="og:image" content={resolvedOgImage} />
  <meta property="og:site_name" content="Widde" />
  <meta property="og:locale" content="pt_BR" />
  {datePublished && <meta property="article:published_time" content={datePublished} />}

  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={ogTitle ?? title} />
  <meta name="twitter:description" content={ogDescription ?? description} />
  <meta name="twitter:image" content={resolvedOgImage} />

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Lato:wght@400;700;900&display=swap" onload="this.onload=null;this.rel='stylesheet'" />
  <noscript><link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Lato:wght@400;700;900&display=swap" /></noscript>

  <link rel="icon" href="/assets/ico.png" type="image/png" />
  <link rel="apple-touch-icon" href="/assets/ico.png" />
  <link rel="sitemap" type="application/xml" href="/sitemap.xml" />
  <ClientRouter />
  <script is:inline>
    document.addEventListener('astro:after-swap', () => {
      const lenis = window.__lenis;
      if (lenis) {
        lenis.scrollTo(0, { immediate: true });
      } else {
        window.scrollTo(0, 0);
      }
    });
  </script>

  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    "name": "Widde",
    "url": "https://widde.io",
    "logo": "https://widde.io/logo.png",
    "description": "Plataforma de Video Commerce, Live Commerce e TryOn para e-commerces.",
    "sameAs": [
      "https://www.instagram.com/widde.io",
      "https://www.linkedin.com/company/widde",
      "https://www.youtube.com/@widde",
      "https://www.tiktok.com/@widde.io"
    ],
    "contactPoint": {
      "@type": "ContactPoint",
      "contactType": "sales",
      "availableLanguage": "Portuguese"
    }
  }
  </script>

  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "Widde",
    "url": "https://widde.io"
  }
  </script>
  {blogPostingSchema && <script type="application/ld+json" set:html={JSON.stringify(blogPostingSchema)} />}
  {breadcrumbSchema && <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />}
</head>
<body>
  <slot />
</body>
</html>
