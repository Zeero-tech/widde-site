---
import '../styles/global.css'

interface Props {
  title: string
  description: string
  canonical: string
  ogTitle?: string
  ogDescription?: string
  ogUrl?: string
  ogImage?: string
  ogType?: string
  datePublished?: string
  author?: string
}

const {
  title,
  description,
  canonical,
  ogTitle,
  ogDescription,
  ogUrl,
  ogImage,
  ogType,
  datePublished,
  author,
} = Astro.props

const resolvedOgImage = ogImage ?? 'https://widde.io/assets/logo_cover.jpeg'
const resolvedOgType = ogType ?? 'website'

const blogPostingSchema = resolvedOgType === 'article' ? {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "headline": title,
  "description": description,
  "image": resolvedOgImage,
  "datePublished": datePublished,
  "author": {
    "@type": "Organization",
    "name": author ?? "Widde",
    "url": "https://widde.io"
  },
  "publisher": {
    "@type": "Organization",
    "name": "Widde",
    "logo": {
      "@type": "ImageObject",
      "url": "https://widde.io/logo.png"
    }
  },
  "mainEntityOfPage": canonical
} : null
---

<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

  <title>{title}</title>
  <meta name="description" content={description} />
  <meta name="robots" content="index, follow" />
  <link rel="canonical" href={canonical} />

  <meta property="og:type" content={resolvedOgType} />
  <meta property="og:title" content={ogTitle ?? title} />
  <meta property="og:description" content={ogDescription ?? description} />
  <meta property="og:url" content={ogUrl ?? canonical} />
  <meta property="og:image" content={resolvedOgImage} />
  <meta property="og:site_name" content="Widde" />
  <meta property="og:locale" content="pt_BR" />
  {datePublished && <meta property="article:published_time" content={datePublished} />}

  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={ogTitle ?? title} />
  <meta name="twitter:description" content={ogDescription ?? description} />
  <meta name="twitter:image" content={resolvedOgImage} />

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Lato:wght@400;700;900&display=swap" onload="this.onload=null;this.rel='stylesheet'" />
  <noscript><link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Lato:wght@400;700;900&display=swap" /></noscript>

  <link rel="icon" href="/assets/ico.png" type="image/png" />
  <link rel="apple-touch-icon" href="/assets/ico.png" />
  <link rel="sitemap" type="application/xml" href="/sitemap.xml" />

  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    "name": "Widde",
    "url": "https://widde.io",
    "logo": "https://widde.io/logo.png",
    "description": "Plataforma de Video Commerce, Live Commerce e TryOn para e-commerces.",
    "sameAs": [
      "https://www.instagram.com/widde.io",
      "https://www.linkedin.com/company/widde",
      "https://www.youtube.com/@widde",
      "https://www.tiktok.com/@widde.io"
    ],
    "contactPoint": {
      "@type": "ContactPoint",
      "contactType": "sales",
      "availableLanguage": "Portuguese"
    }
  }
  </script>

  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "Widde",
    "url": "https://widde.io"
  }
  </script>
  {blogPostingSchema && <script type="application/ld+json" set:html={JSON.stringify(blogPostingSchema)} />}
</head>
<body>
  <slot />
  <script defer src="https://d335luupugsy2.cloudfront.net/js/rdstation-forms/stable/rdstation-forms.min.js"></script>
  <script is:inline>
    (function () {
      // ===== CONFIGURAÇÃO =====
      const YOUTUBE_VIDEO_ID = 'GaM07iLj4_Q';
      const GOOGLE_MEET_URL = 'https://meet.google.com/pap-qfjc-kry';
      const TITLE = 'Dia dos Namorados — O cupido tem dúvida<br>(e seu cliente também)';
      const BUTTON_COLOR = '#2767f8';
      const STORAGE_KEY = 'live_modal_dismissed';
      // Janela de exibição: hoje (28/05/2026) das 11:00 às 12:00
      const SHOW_FROM = new Date('2026-05-28T11:00:00');
      const SHOW_UNTIL = new Date('2026-05-28T12:00:00');
      // =========================

      const now = new Date();
      if (now < SHOW_FROM || now >= SHOW_UNTIL) return;

      if (localStorage.getItem(STORAGE_KEY) === 'true') return;

      if (document.getElementById('live-modal-container')) return;

      const fontLink = document.createElement('link');
      fontLink.rel = 'stylesheet';
      fontLink.href = 'https://fonts.googleapis.com/css2?family=Lato:wght@400;600;700&display=swap';
      document.head.appendChild(fontLink);

      const style = document.createElement('style');
      style.textContent = `
        #live-modal-container {
          position: fixed;
          bottom: 20px;
          left: 20px;
          width: 420px;
          max-width: calc(100vw - 40px);
          background: #1a1a1a;
          border-radius: 12px;
          box-shadow: 0 8px 32px rgba(0,0,0,0.4);
          z-index: 999999;
          font-family: "Lato", -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
          overflow: hidden;
          animation: live-modal-slide-in 0.3s ease-out;
        }
        @media (max-width: 480px) {
          #live-modal-container {
            width: 100vw;
            max-width: 100vw;
            bottom: 0;
            left: 0;
            border-radius: 12px 12px 0 0;
          }
        }
        @keyframes live-modal-slide-in {
          from { transform: translateY(20px); opacity: 0; }
          to   { transform: translateY(0);    opacity: 1; }
        }
        #live-modal-close {
          position: absolute;
          top: 8px;
          right: 8px;
          width: 28px;
          height: 28px;
          border-radius: 50%;
          background: rgba(0,0,0,0.6);
          color: #fff;
          border: none;
          cursor: pointer;
          font-size: 16px;
          line-height: 1;
          display: flex;
          align-items: center;
          justify-content: center;
          z-index: 2;
          transition: background 0.2s;
        }
        #live-modal-close:hover { background: rgba(0,0,0,0.9); }
        #live-modal-title {
          padding: 12px 40px;
          background: #1a1a1a;
          color: #fff;
          font-size: 13px;
          font-weight: 600;
          line-height: 1.35;
          text-align: center;
        }
        #live-modal-video {
          position: relative;
          width: 100%;
          aspect-ratio: 16 / 9;
          background: #000;
        }
        #live-modal-video iframe {
          width: 100%;
          height: 100%;
          border: 0;
          display: block;
        }
        #live-modal-meet-btn {
          display: block;
          width: 100%;
          padding: 12px 16px;
          background: #2767f8;
          color: #fff;
          text-align: center;
          text-decoration: none;
          font-size: 14px;
          font-weight: 600;
          border: none;
          cursor: pointer;
          transition: filter 0.2s;
        }
        #live-modal-meet-btn:hover { filter: brightness(0.9); }
      `;
      document.head.appendChild(style);

      const container = document.createElement('div');
      container.id = 'live-modal-container';
      container.innerHTML = `
        <button id="live-modal-close" aria-label="Fechar">✕</button>
        <div id="live-modal-title">${TITLE}</div>
        <div id="live-modal-video">
          <iframe
            src="https://www.youtube.com/embed/${YOUTUBE_VIDEO_ID}?autoplay=1&mute=1"
            allow="autoplay; encrypted-media"
            allowfullscreen>
          </iframe>
        </div>
        <a id="live-modal-meet-btn" href="${GOOGLE_MEET_URL}" target="_blank" rel="noopener">
          Acompanhar no Google Meet
        </a>
      `;
      document.body.appendChild(container);

      document.getElementById('live-modal-close').addEventListener('click', function () {
        localStorage.setItem(STORAGE_KEY, 'true');
        container.remove();
      });
    })();
  </script>
</body>
</html>
