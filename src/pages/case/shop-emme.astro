---
import BaseLayout from '../../layouts/BaseLayout.astro'
import CaseArticle from '../../components/CaseArticle'
import type { CaseArticleData } from '../../components/CaseArticle'

const data: CaseArticleData = {
  heroImage: "https://cdn.prod.website-files.com/65596f4cd628c3fb6449f35f/682f71f1302a909a7f79efe8_Case%20Shop%20Emme.avif",
  tag: "Case de Sucesso",
  title: "Mais de R$ 1 milhão em vendas com o Video Commerce na Black Friday",
  representanteNome: "Malu Carneiro",
  representanteCargo: "Fundadora da Shop Emme",
  cliente: "Shop Emme",
  youtubeUrl: "https://youtu.be/TBFu8MVc-fI",

  conhecaLogo: "https://cdn.prod.website-files.com/65596f4cd628c3fb6449f35f/682f71f1302a909a7f79efe8_Case%20Shop%20Emme.avif",
  conhecaTitle: "Conheça a Shop Emme",
  conhecaBody: `<p>A Shop Emme é uma marca de moda feminina, focada em alfaiataria, fundada em 2019, por Maria Luiza Carneiro. Ela iniciou com Malu comprando e vendendo cintos, e hoje já conta com 15 colaboradores, um e-commerce, uma loja física e mais de 6 dígitos faturados mensalmente.</p>`,
  conhecaNumbers: [
    { value: "6 dígitos", label: "Faturados mensalmente" },
    { value: "5 anos", label: "No mercado" },
  ],

  depoimento1Img: "https://cdn.prod.website-files.com/65596f4cd628c3fb6449f35f/682f723ceed32388c7b21544_Malu%20shop%20emme.avif",
  depoimento1Quote: "Quando não tinha vídeo na página do produto, as clientes passavam por ela muito rápido. Mas quando tinha vídeos, elas assistiam e colocavam o produto no carrinho. Depois disso, vimos a importância e começamos a colocar a Widde na rotina de lançamentos da loja.",
  depoimento1Nome: "Malu Carneiro",
  depoimento1Cargo: "Fundadora da Shop Emme",

  desafioGif: "https://cdn.prod.website-files.com/65596f4cd628c3fb6449f35f/682f74b65c0cf14b0eadbac2_Screenshot%202025-05-22%20at%2016.00.19.avif",
  desafioBody: `<p>A marca estava conseguindo levar muitos consumidores para o site, através do tráfego pago principalmente, no entanto, a taxa de conversão precisava ser melhorada. Isso porque, o público que chegava ainda não conhecia a loja e não estava ativo acompanhando os conteúdos postados nas redes sociais, além de não ter identificação com as fotos profissionais dos shootings.</p><p>Outro desafio era a necessidade de aproveitar melhor os conteúdos gravados, para não perder em 24h no story do Instagram. Foi assim que em maio de 2024, a Shop Emme começou a usar a solução de Video Commerce da Widde, visando o aumento de conversão de vendas no e-commerce, humanização e economia em anúncios on-line.</p>`,

  numeros: [
    { value: "R$ 1.072.854,35", label: "Receita impactada na Black Friday" },
    { value: "4,42%", label: "Taxa de conversão com os vídeos" },
    { value: "8min 40s", label: "Tempo de retenção com os vídeos" },
  ],

  resultadosGif: "https://cdn.prod.website-files.com/65596f4cd628c3fb6449f35f/682f7868eeceadf1f5d805b4_emme-group.avif",

  resultadosBody: `<p>Através dos vídeos em formatos mais descontraídos, foi possível trazer humanização para dentro do e-commerce e criar conexão com o público que ainda não conhecia a Shop Emme. Nos conteúdos, Malu também traz informações de forma direta que auxiliam a tirar dúvidas das clientes, como: detalhes do tecido, caimento, textura, medidas, formas de usar e muito mais. Essa estratégia traz autonomia para o consumidor tomar uma decisão de compra mais assertiva.</p><p>Além disso, a equipe fez uma análise da navegação dos clientes no site, por um mapa de calor, e a conclusão foi: quando não tinham vídeos, a retenção e a conversão eram baixas. Já com os vídeos, os consumidores passavam mais tempo e compravam os produtos.</p>`,

  depoimento2Quote: "Não meçam esforços em colocar vídeos no e-commerce. Essa é uma iniciativa para humanizar o seu e-commerce e ter uma comunicação direta com o seu cliente. Você vai cativar ele e passar mais segurança. O vídeo faz muita diferença e a taxa de conversão aumenta demais.",
  depoimento2Nome: "Malu Carneiro",
  depoimento2Cargo: "Fundadora da Shop Emme",
  depoimento2ImgVertical: "https://cdn.prod.website-files.com/65596f4cd628c3fb6449f35f/682f7868eeceadf1f5d805b4_emme-group.avif",
  depoimento2YoutubeUrl: "https://youtu.be/TBFu8MVc-fI",

  greyStickyBody: `<h2><strong>Black Friday: A estratégia para vender muito mais</strong></h2><p>A marca apostou em duas estratégias principais:</p><h3><strong>1ª Combinar itens em promoção com coleção nova</strong></h3><p>Aproveitaram os conteúdos que já iriam ser gravados para o lançamento, como provador e vídeos para a Widde, para combinar com outros que já estavam parados há algum tempo. Essa iniciativa foi eficiente para evidenciar as peças necessárias, resultando em um sold out do estoque para a Black Friday.</p><h3><strong>2ª Feed de Vídeos dentro do e-commerce</strong></h3><p>Com o intuito de trazer a interatividade das redes sociais sem distrações, a Shop Emme criou uma página focada apenas nos vídeos, para as clientes conhecerem mais produtos e consumirem os conteúdos da loja.</p>`,
  greyStickyYoutubeUrl: "https://youtu.be/TBFu8MVc-fI",

  outrosCases: [
    { href: "/case/mamo", img: "https://cdn.prod.website-files.com/65596f4cd628c3fb6449f35f/695d2d0b1016c8df8923096d_capa%20youtube%201.png", title: "Construindo narrativas com Video Commerce" },
    { href: "/case/john-john", img: "https://cdn.prod.website-files.com/65596f4cd628c3fb6449f35f/68c2cc161322055b66b7b9b9_Capa%20John%20John.png", title: "Agregando valor ao produto com o Video Commerce" },
    { href: "/case/maximum-boxing", img: "https://cdn.prod.website-files.com/65596f4cd628c3fb6449f35f/689de10eed3215b5ef778578_Maximum%20Boxing%20capa%20case.png", title: "Mais vendas, menos demanda para o SAC" },
    { href: "/case/majeste", img: "https://cdn.prod.website-files.com/65596f4cd628c3fb6449f35f/6836d7610a4f73f81a121f54_capa%20majeste%CC%81.avif", title: "Desafios da Moda Festa no E-commerce" },
  ],
}
---

<BaseLayout
  title="Shop Emme: Mais de R$ 1 milhão em vendas com Video Commerce na Black Friday | Widde"
  description="Veja como a Shop Emme usou o Video Commerce da Widde para alcançar R$ 1.072.854,35 de receita impactada na Black Friday e 4,42% de taxa de conversão."
  canonical="https://widde.io/case/shop-emme"
>
  <CaseArticle client:load data={data} />
</BaseLayout>
