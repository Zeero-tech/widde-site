  <BlogArticle
    client:load
    title="Como adicionar vídeo de produtos na Loja Integrada?"
    category="Video Commerce"
    date="27.03.2025"
    readingTime="5 minutos de leitura"
    coverImage="/assets/blog/como-adicionar-video-de-produtos-na-loja-integrada/67e5878473e435b3211ba082_Como-adicionar-v-deo-loja-integrada.avif"
