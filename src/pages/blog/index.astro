---
import { getCollection } from 'astro:content'
import BaseLayout from '@/layouts/BaseLayout.astro'

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf())

const formatter = new Intl.DateTimeFormat('pt-BR', { day: '2-digit', month: 'short', year: 'numeric' })
---

<BaseLayout
  title="Blog | Widde"
  description="Artigos, dados e insights sobre Video Commerce, Live Commerce, TryOn e o futuro do e-commerce no Brasil."
  canonical="https://widde.io/blog"
>
  <main class="max-w-screen-xl mx-auto px-5 md:px-10 lg:px-12 py-12 md:py-20">
    <header class="mb-12 md:mb-16">
      <p class="text-xs md:text-sm font-bold text-text-muted uppercase tracking-[1px] mb-3">
        Blog Widde
      </p>
      <h1 class="text-4xl md:text-6xl font-bold text-charcoal leading-tight">
        Conteúdo para acelerar suas vendas no e-commerce
      </h1>
    </header>

    {posts.length === 0 ? (
      <p class="text-text-muted">Nenhum post publicado ainda.</p>
    ) : (
      <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-6">
        {posts.map((post) => (
          <a
            href={`/blog/${post.id}`}
            class="rounded-[14px] overflow-hidden shadow-[0_0_0_1px_rgb(233,233,233)] hover:shadow-[0_4px_20px_rgba(0,0,0,0.08)] transition-shadow flex flex-col bg-white"
          >
            {post.data.cover && (
              <div class="w-full h-[200px] md:h-[220px] relative">
                <img
                  src={post.data.cover}
                  alt={post.data.coverAlt ?? post.data.title}
                  class="absolute inset-0 w-full h-full object-cover"
                  loading="lazy"
                />
              </div>
            )}
            <div class="flex flex-col flex-1 p-5 gap-2">
              <p class="text-xs font-bold text-text-muted uppercase tracking-[1px]">
                {post.data.category}
              </p>
              <h2 class="text-xl md:text-2xl font-normal text-charcoal leading-[1.3]">
                {post.data.title}
              </h2>
              <p class="text-base text-text-muted leading-[1.5]">
                {post.data.description}
              </p>
              <div class="flex items-center justify-between mt-auto pt-3">
                <time class="text-sm text-text-faint" datetime={post.data.publishedAt.toISOString()}>
                  {formatter.format(post.data.publishedAt)}
                </time>
                <span class="font-bold text-navy">Ler →</span>
              </div>
            </div>
          </a>
        ))}
      </div>
    )}
  </main>
</BaseLayout>
