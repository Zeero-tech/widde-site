    title="Como elaborar uma página de produto de alta conversão"
    category="Tendências e-commerce"
    date="12.05.2025"
    readingTime="8 minutos de leitura"
    coverImage="/assets/blog/como-elaborar-uma-pagina-de-produto-de-alta-conversao/6672db5abd3718b21562ec32_P-gina-de-produtos-de-alta-convers-o.avif"
    currentSlug="como-elaborar-uma-pagina-de-produto-de-alta-conversao"
