---
import BaseLayout from "../layouts/BaseLayout.astro";
import WebinarDiaNamoradosPage from "../components/pages/WebinarDiaNamoradosPage";
---

<BaseLayout
  title="Webinar Dia dos Namorados: O cupido tem dúvida (e seu cliente também)"
  description="Aprenda a usar o Video Commerce, Live Commerce e Provador IA para vender mais no Dia dos Namorados, dentro da janela certa. Webinar ao vivo, sem gravação."
  canonical="https://widde.io/webinar-dia-namorados"
  noindex={true}
  ogTitle="Webinar Dia dos Namorados: O cupido tem dúvida (e seu cliente também)"
  ogDescription="Aprenda a usar o Video Commerce, Live Commerce e Provador IA para vender mais no Dia dos Namorados, dentro da janela certa. Webinar ao vivo, sem gravação."
>
  <WebinarDiaNamoradosPage client:load />
</BaseLayout>

<style is:global>
  body {
    background-color: rgb(115, 11, 0);
  }

  .webinar-form-col {
    opacity: 0;
  }

  #webinar-dia-dos-namorados-27-05-c7e6488e37d086da8074 h2 {
    color: #000 !important;
    font-size: 1.6rem !important;
    margin-bottom: 1.2rem !important;
  }
  #webinar-dia-dos-namorados-27-05-c7e6488e37d086da8074 .bricks-form__label {
    color: #000 !important;
    font-size: 0.9rem !important;
  }
  #webinar-dia-dos-namorados-27-05-c7e6488e37d086da8074 .bricks-form__input {
    background-color: #e9e9e9 !important;
    color: #000 !important;
    border: none !important;
    border-radius: 8px !important;
    padding: 10px 14px !important;
    width: 100% !important;
    box-sizing: border-box !important;
  }
  #webinar-dia-dos-namorados-27-05-c7e6488e37d086da8074 input.bricks-form__input::placeholder {
    color: transparent !important;
  }
  #webinar-dia-dos-namorados-27-05-c7e6488e37d086da8074 .rd-button {
    background-color: #000 !important;
    color: #fff !important;
    border: none !important;
    border-radius: 9999px !important;
    padding: 12px 28px !important;
    font-weight: 700 !important;
    font-size: 1rem !important;
    cursor: pointer !important;
    width: 100% !important;
    margin-top: 8px !important;
  }
  #webinar-dia-dos-namorados-27-05-c7e6488e37d086da8074 .rd-button:hover {
    background-color: #333 !important;
  }
  #webinar-dia-dos-namorados-27-05-c7e6488e37d086da8074 .bricks-form__fieldset {
    display: flex !important;
    flex-direction: column !important;
    gap: 12px !important;
  }
  #webinar-dia-dos-namorados-27-05-c7e6488e37d086da8074 select.bricks-form__input {
    background-color: #e9e9e9 !important;
    color: #000 !important;
    height: 48px !important;
    padding: 10px 14px !important;
  }
  #webinar-dia-dos-namorados-27-05-c7e6488e37d086da8074 .bricks-form__field__option label {
    color: #000 !important;
  }
  #webinar-dia-dos-namorados-27-05-c7e6488e37d086da8074 .bricks-form__field:has(input[name="cf_cliente_da_widde"]) {
    display: flex !important;
    flex-direction: column !important;
    align-items: flex-start !important;
    gap: 8px !important;
  }
  @media (min-width: 880px) {
    #webinar-dia-dos-namorados-27-05-c7e6488e37d086da8074 .bricks-form__field:has(input[name="cf_cliente_da_widde"]) {
      flex-direction: row !important;
      align-items: center !important;
      gap: 16px !important;
    }
  }
  #webinar-dia-dos-namorados-27-05-c7e6488e37d086da8074 .bricks-form__field:has(input[name="cf_cliente_da_widde"]) .always-visible {
    margin-bottom: 0 !important;
    white-space: nowrap !important;
  }
  #webinar-dia-dos-namorados-27-05-c7e6488e37d086da8074 .bricks-form__field:has(input[name="cf_cliente_da_widde"]) .bricks-form__field__option {
    margin: 0 !important;
  }
  #webinar-dia-dos-namorados-27-05-c7e6488e37d086da8074 .phone-input-group {
    display: flex !important;
    align-items: center !important;
  }
  #webinar-dia-dos-namorados-27-05-c7e6488e37d086da8074 .select2-container.phone-country {
    display: flex !important;
    align-items: center !important;
    justify-content: center !important;
    min-width: 70px !important;
  }
  #webinar-dia-dos-namorados-27-05-c7e6488e37d086da8074 .select2-choice {
    display: flex !important;
    align-items: center !important;
    height: 100% !important;
  }
</style>
